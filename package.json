{
    "name": "roadside_station_maps",
    "version": "0.1.0",
    "type": "module",
    "files": [
        "data",
        "html"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/tk0miya/roadside_station_maps"
    },
    "main": "html/js/bundle.js",
    "scripts": {
        "start": "npx tsx esbuild.config.ts --watch",
        "build": "npx tsx esbuild.config.ts",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.backend.json",
        "serve": "npx tsx esbuild.config.ts --serve",
        "dev": "npm run serve",
        "dev:backend": "wrangler dev",
        "deploy:backend": "wrangler deploy --env production",
        "db:migrate:local": "wrangler d1 migrations apply DB --local",
        "db:migrate": "wrangler d1 migrations apply DB --remote --env production",
        "generate:geojson": "npx tsx src/scripts/generate-geojson.ts",
        "generate:stations": "npx tsx src/scripts/generate-stationlist.ts",
        "generate:all": "npm run generate:stations && npm run generate:geojson",
        "test": "vitest",
        "ci": "npm run lint && npm run typecheck && npm test"
    },
    "dependencies": {
        "@react-oauth/google": "^0.13.5",
        "cheerio": "^1.2.0",
        "clipboard": "^2.0.11",
        "hono": "^4.12.16",
        "jaconv": "^1.1.2",
        "jose": "^6.2.3",
        "openid-client": "^6.8.4",
        "query-string": "^9.3.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.13",
        "@cloudflare/workers-types": "^4.20260502.1",
        "@testing-library/react": "^16.3.2",
        "@types/cheerio": "^1.0.0",
        "@types/clipboard": "^2.0.10",
        "@types/google.maps": "^3.64.0",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "esbuild": "^0.28.0",
        "jsdom": "^29.0.2",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5",
        "wrangler": "^4.87.0"
    }
}
